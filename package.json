{
  "name": "surikumpas",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "npx expo start",
    "android": "npx expo run:android",
    "ios": "npx expo run:ios",
    "web": "npx expo start --web",
    "clean": "rd /s /q .expo 2>nul & rd /s /q node_modules 2>nul & rd /s /q %TEMP%\\metro-* 2>nul & rd /s /q %TEMP%\\haste-map-* 2>nul & npm cache clean --force",
    "clean-start": "npm run clean & npm install --legacy-peer-deps & npx expo start --clear"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@pixiv/three-vrm": "^2.1.2",
    "@react-native-voice/voice": "^3.2.4",
