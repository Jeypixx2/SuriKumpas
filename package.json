    "expo-asset": "~12.0.0",
    "expo-build-properties": "^55.0.12",
    "expo-camera": "~17.0.0",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.0",
    "expo-gl": "~16.0.0",
    "expo-linking": "~8.0.0",
    "expo-modules-core": "~3.0.0",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "expo-three": "~8.0.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
